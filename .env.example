PORT=5000
MONGODB_URI=mongodb://localhost:27017/taskflow

# In production (Render, Railway, Vercel, etc.) use your Atlas connection string:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/taskflow

JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRE=7d

# Production: set this to your deployed frontend URL (no trailing slash)
# Example: https://taskflow.vercel.app  or  https://taskflow.netlify.app
CLIENT_URL=http://localhost:5173

NODE_ENV=development

# Server configuration
PORT=5000
NODE_ENV=development

# Database
# Local MongoDB if you have it running, otherwise grab a free Atlas string
MONGODB_URI=mongodb://localhost:27017/taskflow

# Auth Secrets
# Grab a long random string for production. Don't leave this as 'secret'.
JWT_SECRET=keyboard_cat_or_something_actually_secure
JWT_EXPIRE=7d

# Bot Protection
# Get these from the Google ReCaptcha Admin Console (v3 Invisible)
RECAPTCHA_SECRET_KEY=your_secret_key_here

# URLs
# Must match your frontend's actual URL. Local dev is usually 5173.
CLIENT_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Mailer (SMTP)
# Using Gmail? You'll need an 'App Password'. 
# Standard port is 465 (secure) or 587.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_no_spaces
EMAIL_FROM=TaskFlow <noreply@taskflow.com>
